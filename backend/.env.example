# 复制为 .env 后修改。数据库在 Docker 容器 gfms 内时：
# - 后端在宿主机运行：MYSQL_HOST=127.0.0.1，端口填映射到主机的端口（常见 3306）
# - 后端与 MySQL 在同一 Docker 网络：MYSQL_HOST=gfms

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=lost_found

SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 逗号分隔，无空格
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

PUBLIC_BASE_URL=http://127.0.0.1:8000
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# 图像识别模型：LLM_MODE=local 使用本机 Ollama；LLM_MODE=remote 使用远程 API（OpenAI 兼容）
LLM_MODE=local
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-vl:7b
# remote 时填写，例如 https://api.openai.com/v1 或厂商提供的 compatible-mode/v1 根路径
REMOTE_LLM_BASE_URL=
REMOTE_LLM_API_KEY=
REMOTE_LLM_MODEL=
